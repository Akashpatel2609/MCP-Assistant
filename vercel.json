{
  "version": 2,
  "routes": [
    {
      "src": "/app.js",
      "dest": "/app.js"
    },
    {
      "src": "/style.css",
      "dest": "/style.css"
    },
    {
      "src": "/(sessions|upload|files|health|ws|chat)/(.*)",
      "dest": "api/index.py"
    },
    {
      "src": "/(sessions|upload|files|health|ws|chat)",
      "dest": "api/index.py"
    },
    {
      "src": "/(.*)",
      "dest": "/index.html"
    }
  ]
}
