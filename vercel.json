{
  "version": 2,
  "builds": [
    {
      "src": "api/index.py",
      "use": "@vercel/python"
    },
    {
      "src": "frontend/**",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    {
      "src": "/static/(.*)",
      "dest": "frontend/$1"
    },
    {
      "src": "/(assets|images)/(.*)",
      "dest": "frontend/$1/$2"
    },
    {
      "src": "/(sessions|upload|files|health|ws)/(.*)",
      "dest": "api/index.py"
    },
    {
      "src": "/(sessions|upload|files|health|ws)",
      "dest": "api/index.py"
    },
    {
      "src": "/(.*)",
      "dest": "frontend/index.html"
    }
  ]
}
